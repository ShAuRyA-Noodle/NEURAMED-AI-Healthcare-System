VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/live-feed

# Public demo doctor invite code shown on the login page (must match backend
# DOCTOR_INVITE_CODE). Remove/blank for a real deployment.
VITE_DEMO_DOCTOR_CODE=NEURAMED-DEMO-2026

# Decorative 3D/WebGL backgrounds (ambient field, hero, voice orb). OFF by
# default — they are GPU-heavy and broke rendering on some hardware. Set true to enable.
VITE_ENABLE_3D=false
