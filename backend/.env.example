# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit it.

# Required — Groq API key for LLM inference (LLaMA 3 70B + vision models)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional — ElevenLabs for TTS (voice agent + plain-language read-aloud)
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional — Google API key (Maps / Translate / Cloud — depends on usage)
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your_google_api_key_here

# Required for OCR fallback — path to Tesseract binary
# Linux container default: /usr/bin/tesseract
# Windows local default: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=/usr/bin/tesseract

# Local dev may use SQLite. Production MUST use Postgres —
# SQLite on an ephemeral filesystem loses all data on redeploy.
DATABASE_URL=postgresql://user:password@host:5432/neuramed

# CORS — comma-separated allowed origins. "*" is allowed in dev/test only;
# in production the app REFUSES to start with "*" (fail-closed). Set it to your
# deployed frontend origin(s), e.g.:
#   ALLOWED_ORIGINS=https://your-frontend.vercel.app
ALLOWED_ORIGINS=*

# JWT signing secret. Dev/test may leave it unset (a default is used with a
# warning). In production the app REFUSES to start if unset or default.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Set it as an env var on your host — do NOT commit the real value.
SECRET_KEY=

# Doctor role gate. Anyone registering as a doctor must supply this code.
# For the public DEMO, use a shareable code and show it on the login page via
# the frontend VITE_DEMO_DOCTOR_CODE (synthetic data only). For a REAL
# deployment, use a private code and remove the on-screen hint.
# In production the app REFUSES to start if unset or the old default.
DOCTOR_INVITE_CODE=NEURAMED-DEMO-2026

# development | production | test. Production enables fail-closed checks above.
ENVIRONMENT=development
UPLOAD_DIR=./uploads
