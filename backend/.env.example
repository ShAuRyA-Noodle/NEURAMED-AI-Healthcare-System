# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit it.

# ── REQUIRED: App secrets ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Strong random code — distribute to doctors out-of-band (not in code, not in docs)
DOCTOR_INVITE_CODE=

# ── REQUIRED: AI provider ─────────────────────────────────────────────────────
GROQ_API_KEY=

# ── OPTIONAL: Additional AI/services ─────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── REQUIRED: Database ───────────────────────────────────────────────────────
# Production: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./neuramed.db

# ── REQUIRED in production: CORS ─────────────────────────────────────────────
# Comma-separated. If unset, only localhost is allowed (dev fallback).
# Example: https://yourapp.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── OCR (optional) ───────────────────────────────────────────────────────────
# Linux: /usr/bin/tesseract | Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=/usr/bin/tesseract

# ── Environment ──────────────────────────────────────────────────────────────
# Set to "production" to enable HSTS, disable /docs, enforce secure cookies
ENVIRONMENT=development
