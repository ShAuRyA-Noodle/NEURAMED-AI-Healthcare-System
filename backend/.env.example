# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit it.

# Required — Groq API key for LLM inference (LLaMA 3 70B + vision models)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional — ElevenLabs for TTS (voice agent + plain-language read-aloud)
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional — Google API key (Maps / Translate / Cloud — depends on usage)
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your_google_api_key_here

# Required for OCR fallback — path to Tesseract binary
# Linux container default: /usr/bin/tesseract
# Windows local default: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=/usr/bin/tesseract

# Local dev may use SQLite. Production MUST use Postgres —
# SQLite on an ephemeral filesystem loses all data on redeploy.
DATABASE_URL=postgresql://user:password@host:5432/neuramed

# CORS — comma-separated allowed origins. Use * for dev only.
# Example prod: https://your-frontend.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=*

ENVIRONMENT=development
UPLOAD_DIR=./uploads
